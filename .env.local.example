# Copie para .env.local e preencha com os dados do seu projeto Supabase.
# .env.local NÃO é commitado (está no .gitignore).

# Públicas (vão para o browser) — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Secreta — usada SÓ pelo seed/ETL (server-side). NUNCA exponha no client
# nem commite. Project Settings > API > service_role.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
